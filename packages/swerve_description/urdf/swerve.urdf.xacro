<?xml version="1.0"?>
<!--
  @Desc   四转四驱舵轮底盘 URDF
          转向：灵足时代 RS06（CAN5，扩展帧）
          驱动：和利时 UM 系列伺服轮毂一体机（CAN4，CANopen CiA402 PV 速度模式）
          机械尺寸：wheel_radius=0.075m，wheel_width=0.06m，轮距 0.547m，轴距 0.42m
-->

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="swerve_chassis">

  
  <xacro:arg name="use_gazebo" default="false"/>  <!-- 保留参数兼容，实车始终 false -->
  <xacro:arg name="use_mock" default="false"/>
  <xacro:arg name="steering_can_interface" default="can5"/>
  <xacro:arg name="driving_can_interface" default="can4"/>
  <xacro:arg name="controllers_file" default=""/>
  <xacro:arg name="robot_param_node" default="robot_state_publisher"/>

  
  <xacro:property name="wheel_radius" value="0.075"/>
  <xacro:property name="wheel_width" value="0.06"/>
  <xacro:property name="wheelbase" value="0.42"/>
  <xacro:property name="track_width" value="0.547"/>
  <xacro:property name="half_wheelbase" value="${wheelbase / 2.0}"/>
  <xacro:property name="half_track" value="${track_width / 2.0}"/>

  <xacro:property name="chassis_length" value="0.50"/>
  <xacro:property name="chassis_width" value="0.40"/>
  <xacro:property name="chassis_height" value="0.14"/>  
  <xacro:property name="chassis_mass" value="20.0"/>

  <xacro:property name="steering_link_height" value="0.05"/>
  <xacro:property name="steering_link_radius" value="0.03"/>
  <xacro:property name="steering_mass" value="0.5"/>
  <xacro:property name="wheel_mass" value="2.0"/>
  <xacro:property name="mid360_mass" value="0.35"/>
  <!-- Livox MID-360 STL（毫米）；仅 visual；mid360_joint 安装位与惯量不变 -->
  <xacro:property name="mid360_mesh_scale" value="0.001 0.001 0.001"/>
  <xacro:property name="mid360_visual_xyz" value="-0.0328 0.0346 -0.0435"/>
  <xacro:property name="mid360_visual_rpy" value="1.5708 0 0"/>
  <xacro:property name="d435_mass" value="0.10"/>
  <!-- Intel RealSense D435 STL（毫米）；仅替换 visual，d435_joint / 惯量不变 -->
  <xacro:property name="d435_mesh_scale" value="0.001 0.001 0.001"/>
  <!-- rpy: 先 Rx 对齐 CAD，再绕 Z（蓝轴）转 -90° 使 X↔Y（与 +90° 反向）；xyz 为质心补偿 -->
  <xacro:property name="d435_visual_xyz" value="0.0152 0.0447 -0.0129"/>
  <xacro:property name="d435_visual_rpy" value="1.5708 0 ${-pi/2}"/>

  <!-- 四轮 mesh：毫米 scale；STL 原点在角点，须 visual/collision 的 xyz 把质心挪到 link 原点（勿用 scale 负值镜像，会把偏心网格甩飞） -->
  <xacro:property name="wheel_mesh_scale" value="0.001 0.001 0.001"/>
  <!-- 由 fl_wheel_link.STL 质心 (~45,75,75)mm 与 rpy 推算，使网格中心落在 wheel_link 原点 -->
  <!-- 两套 visual 姿态：一侧 rpy=pi/2，另一侧 rpy=3pi/2（绕 Z 差 180°）；按 RViz 挂到 fl/bl 与 fr/br -->
  <xacro:property name="wheel_visual_xyz_a" value="-0.075 -0.045 -0.075"/>
  <xacro:property name="wheel_visual_rpy_a" value="1.5708 0 ${pi/2}"/>
  <xacro:property name="wheel_visual_xyz_b" value="0.075 0.045 -0.075"/>
  <xacro:property name="wheel_visual_rpy_b" value="1.5708 0 ${3*pi/2}"/>

  
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12.0}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12.0}" iyz="0"
               izz="${m*(x*x+y*y)/12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12.0}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12.0}" iyz="0"
               izz="${m*r*r/2.0}"/>
    </inertial>
  </xacro:macro>

  
  <xacro:macro name="swerve_module" params="prefix x y motor_id direction wheel_visual_xyz wheel_visual_rpy">
    
    <joint name="${prefix}_steering_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${prefix}_steering_link"/>
      <origin xyz="${x} ${y} ${-(chassis_height/2.0)}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.5708" upper="1.5708" effort="10" velocity="10"/>
    </joint>

    
    <!-- 转向节无 visual（舵机被外壳遮挡）；仅保留 collision 圆柱，仿真/惯量与改前一致 -->
    <link name="${prefix}_steering_link">
      <collision>
        <geometry>
          <cylinder radius="${steering_link_radius}" length="${steering_link_height}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${steering_mass}" r="${steering_link_radius}" h="${steering_link_height}"/>
    </link>

    
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${prefix}_steering_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="0 0 ${-steering_link_height/2.0}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="${wheel_visual_xyz}" rpy="${wheel_visual_rpy}"/>
        <geometry>
          <mesh filename="package://swerve_description/meshes/${prefix}_wheel_link.STL" scale="${wheel_mesh_scale}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="${wheel_visual_xyz}" rpy="${wheel_visual_rpy}"/>
        <geometry>
          <mesh filename="package://swerve_description/meshes/${prefix}_wheel_link.STL" scale="${wheel_mesh_scale}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>
  </xacro:macro>

  
  <link name="base_footprint"/>

  
  <xacro:property name="base_link_z" value="${wheel_radius + steering_link_height/2.0 + chassis_height/2.0}"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 ${-base_link_z}" rpy="0 0 0"/>
  </joint>

  <!-- 底座外壳 STL：先绕 X 转 90° 试放平（原导入为竖立）；仅 visual，collision 仍为方盒 -->
  <xacro:property name="base_shell_visual_rpy" value="1.5708 0 0"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="${base_shell_visual_rpy}"/>
      <geometry>
        <mesh filename="package://swerve_description/meshes/base_link.STL" scale="1 1 1"/>
      </geometry>
      <material name="base_shell_grey">
        <color rgba="0.28 0.28 0.28 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${chassis_mass}"/>
      <inertia ixx="${chassis_mass*(chassis_width*chassis_width+chassis_height*chassis_height)/12.0}" ixy="0" ixz="0"
               iyy="${chassis_mass*(chassis_length*chassis_length+chassis_height*chassis_height)/12.0}" iyz="0"
               izz="${chassis_mass*(chassis_length*chassis_length+chassis_width*chassis_width)/12.0}"/>
    </inertial>
  </link>

  
  <xacro:swerve_module prefix="fl" x="${half_wheelbase}" y="${half_track}" motor_id="5" direction="1"
    wheel_visual_xyz="${wheel_visual_xyz_b}" wheel_visual_rpy="${wheel_visual_rpy_b}"/>
  <xacro:swerve_module prefix="fr" x="${half_wheelbase}" y="${-half_track}" motor_id="6" direction="1"
    wheel_visual_xyz="${wheel_visual_xyz_a}" wheel_visual_rpy="${wheel_visual_rpy_a}"/>
  <xacro:swerve_module prefix="bl" x="${-half_wheelbase}" y="${half_track}" motor_id="7" direction="1"
    wheel_visual_xyz="${wheel_visual_xyz_b}" wheel_visual_rpy="${wheel_visual_rpy_b}"/>
  <xacro:swerve_module prefix="br" x="${-half_wheelbase}" y="${-half_track}" motor_id="8" direction="1"
    wheel_visual_xyz="${wheel_visual_xyz_a}" wheel_visual_rpy="${wheel_visual_rpy_a}"/>

  
  <joint name="mid360_joint" type="fixed">
    <parent link="base_link"/>
    <child link="mid360_link"/>
    <origin xyz="${half_wheelbase + 0.09} 0 ${chassis_height/2.0 + 0.05}" rpy="-0.5236 0 -1.5708"/>
  </joint>
  <link name="mid360_link">
    <visual>
      <origin xyz="${mid360_visual_xyz}" rpy="${mid360_visual_rpy}"/>
      <geometry>
        <mesh filename="package://swerve_description/meshes/mid360_link.STL" scale="${mid360_mesh_scale}"/>
      </geometry>
      <material name="mid360_color">
        <color rgba="0.2 0.4 0.9 1.0"/>
      </material>
    </visual>
    <xacro:cylinder_inertia m="${mid360_mass}" r="0.035" h="0.04"/>
  </link>

  
  <joint name="livox_frame_joint" type="fixed">
    <parent link="mid360_link"/>
    <child link="livox_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="livox_frame"/>

  
  <joint name="d435_joint" type="fixed">
    <parent link="base_link"/>
    <child link="d435_link"/>
    <origin xyz="0.36 0 0.055" rpy="0 0 0"/>
  </joint>
  <link name="d435_link">
    <visual>
      <origin xyz="${d435_visual_xyz}" rpy="${d435_visual_rpy}"/>
      <geometry>
        <mesh filename="package://swerve_description/meshes/d435_link.STL" scale="${d435_mesh_scale}"/>
      </geometry>
      <material name="d435_color">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <xacro:box_inertia m="${d435_mass}" x="0.025" y="0.090" z="0.025"/>
  </link>

  <!-- RealSense driver compatibility frames. Keep d435_link as the physical mount
       while exposing the frame names used by existing RViz, Nav2, and recording nodes. -->
  <joint name="camera_link_joint" type="fixed">
    <parent link="d435_link"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="camera_link"/>

  <joint name="d435_depth_joint" type="fixed">
    <parent link="d435_link"/>
    <child link="d435_depth_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="d435_depth_frame"/>

  <joint name="d435_depth_optical_joint" type="fixed">
    <parent link="d435_depth_frame"/>
    <child link="d435_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>
  <link name="d435_depth_optical_frame"/>

  <joint name="d435_color_joint" type="fixed">
    <parent link="d435_link"/>
    <child link="d435_color_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="d435_color_frame"/>

  <joint name="d435_color_optical_joint" type="fixed">
    <parent link="d435_color_frame"/>
    <child link="d435_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>
  <link name="d435_color_optical_frame"/>

  <joint name="camera_depth_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="camera_depth_frame"/>

  <joint name="camera_depth_optical_joint" type="fixed">
    <parent link="camera_depth_frame"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>
  <link name="camera_depth_optical_frame"/>

  <joint name="camera_rgb_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_rgb_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="camera_rgb_frame"/>

  <joint name="camera_rgb_optical_joint" type="fixed">
    <parent link="camera_rgb_frame"/>
    <child link="camera_rgb_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>
  <link name="camera_rgb_optical_frame"/>

  
  <joint name="imu_joint" type="fixed">
    <parent link="mid360_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="imu_link"/>

  
  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps_link"/>
    <origin xyz="0.06 0 0.24" rpy="0 0 0"/>
  </joint>
  <link name="gps_link"/>

  
  <xacro:include filename="swerve_ros2_control.urdf.xacro"/>

</robot>
