  <!-- ============================================
         4. HEAD SYSTEM
         2-DOF head (pitch + yaw) mounted on lift_carriage_link
         Joint order: pitch (bottom motor, nod up/down) -> yaw (upper motor, turn left/right)
         ============================================ -->
  <!-- Head base link (颈部/底座固定部分) -->
  <link name="head_base_link">
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5630 0.0866 0.0"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/TBBJ-04_neck_mount.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5630 0.0866 0.0"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/TBBJ-02_neck_bracket.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5630 0.0866 0.0"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/TBBJ-06_neck_limit.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5630 0.0866 0.0"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/RS00_motor_2.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <!-- Connect head to lift carriage top -->
  <joint name="head_base_joint" type="fixed">
    <parent link="lift_carriage_link"/>
    <child link="head_base_link"/>
    <origin rpy="0 0 0" xyz="0 0.14 0.1"/>
  </joint>
  <!-- Head pitch link (随底部电机旋转：颈部护罩+上部电机+连接件+护板) -->
  <link name="head_pitch_link">
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5631 0.0798 -0.0395"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/DY-03_neck_cover.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_white">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5631 0.0798 -0.0395"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/RS00_motor_1.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5631 0.0798 -0.0395"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/TB-01_head_connector.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5631 0.0798 -0.0395"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/TBBJ-03_guard_plate.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>
  <!-- Pitch joint (俯仰/抬头低头, bottom motor RS00-2) -->
  <joint name="openarmx_head_pitch_joint" type="revolute">
    <parent link="head_base_link"/>
    <child link="head_pitch_link"/>
    <origin rpy="0 0 0" xyz="0.0001 0.0068 0.0395"/>
    <axis xyz="1 0 0"/>
    <limit effort="14.0" lower="-1.5708" upper="1.5708" velocity="33.0"/>
  </joint>
  <!-- Head yaw link (随上部电机旋转：头部外壳+钣金+摄像头) -->
  <link name="head_yaw_link">
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5631 0.0824 -0.1072"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/TBBJ-01_head_bracket.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5631 0.0824 -0.1072"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/TBBJ-05_head_limit.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5631 0.0824 -0.1072"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/DY-01_head_front_shell.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_white">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5631 0.0824 -0.1072"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/DY-02_head_rear_shell.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_white">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="-0.5631 0.0824 -0.1072"/>
      <geometry>
        <mesh filename="package://openarmx_head_description/meshes/visual/femto_bolt_camera.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="head_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>
  <!-- Yaw joint (偏航/左右摇头, upper motor RS00-1) -->
  <joint name="openarmx_head_yaw_joint" type="revolute">
    <parent link="head_pitch_link"/>
    <child link="head_yaw_link"/>
    <origin rpy="0 0 0" xyz="0.0 -0.0026 0.0677"/>
    <axis xyz="0 0 1"/>
    <limit effort="14.0" lower="-1.5708" upper="1.5708" velocity="33.0"/>
  </joint>
  <!-- Left Arm Hardware Interface -->
  <ros2_control name="openarmx_left_hardware_interface" type="system">
    <hardware>
      <param name="arm_type">v10</param>
